<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/etLoanName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Название кредита (например, Ипотека)"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etLoanTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Общая сумма кредита"
        android:inputType="numberDecimal"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etMonthlyPayment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ежемесячный платёж (сумма)"
        android:inputType="numberDecimal"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etPaymentDay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="День платежа (число от 1 до 31)"
        android:inputType="number"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etMinPayment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Минимальный платёж (если отличается от ежемесячного)"
        android:inputType="numberDecimal" />

</LinearLayout>
